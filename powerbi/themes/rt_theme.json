{
  "name": "rt_theme",
  "dataColors": [
    "#0B3D5C",
    "#00897B",
    "#1A73E8",
    "#5C6BC0",
    "#26A69A",
    "#2E7D32",
    "#C9A227",
    "#E65100",
    "#7E57C2",
    "#29B6F6",
    "#78909C",
    "#455A64"
  ],
  "foreground": "#0B1F33",
  "foregroundNeutralSecondary": "#4A5568",
  "foregroundNeutralTertiary": "#94A3B8",
  "background": "#FFFFFF",
  "backgroundLight": "#F4F7FA",
  "backgroundNeutral": "#DDE3EA",
  "tableAccent": "#00897B",
  "good": "#2E7D32",
  "neutral": "#C9A227",
  "bad": "#C62828",
  "maximum": "#0B3D5C",
  "center": "#C9A227",
  "minimum": "#E3F2FD",
  "null": "#94A3B8",
  "hyperlink": "#00897B",
  "visitedHyperlink": "#0B3D5C",
  "textClasses": {
    "callout": {
      "fontSize": 26,
      "fontFace": "Segoe UI Semibold",
      "color": "#0B1F33"
    },
    "title": {
      "fontSize": 11,
      "fontFace": "Segoe UI Semibold",
      "color": "#0B1F33"
    },
    "header": {
      "fontSize": 10,
      "fontFace": "Segoe UI Semibold",
      "color": "#0B1F33"
    },
    "label": {
      "fontSize": 9,
      "fontFace": "Segoe UI",
      "color": "#4A5568"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#DDE3EA" } },
            "radius": 10,
            "width": 1
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#0B1F33" } },
            "fontSize": 11,
            "bold": true
          }
        ],
        "padding": [
          {
            "top": 12,
            "bottom": 12,
            "left": 16,
            "right": 16
          }
        ],
        "visualHeader": [
          {
            "show": true,
            "foreground": { "solid": { "color": "#0B1F33" } },
            "background": { "solid": { "color": "#FFFFFF" } }
          }
        ],
        "dropShadow": [
          {
            "show": true,
            "color": { "solid": { "color": "#0B1F33" } },
            "position": "Outer",
            "preset": "Custom",
            "transparency": 92,
            "shadowSpread": 0,
            "shadowBlur": 6,
            "angle": 90,
            "shadowDistance": 2
          }
        ],
        "spacing": [
          {
            "customizeSpacing": true,
            "spaceBelowTitle": 8
          }
        ]
      }
    },
    "page": {
      "*": {
        "outspace": [
          {
            "color": { "solid": { "color": "#EEF2F6" } }
          }
        ],
        "background": [
          {
            "color": { "solid": { "color": "#EEF2F6" } },
            "transparency": 0
          }
        ],
        "wallpaper": [
          {
            "transparency": 100
          }
        ]
      }
    },
    "cardVisual": {
      "*": {
        "layout": [
          {
            "maxTiles": 1,
            "cellPadding": 0,
            "paddingUniform": 20,
            "backgroundShow": true
          }
        ],
        "value": [
          {
            "fontFamily": "'Segoe UI Semibold', wf_segoe-ui_semibold, helvetica, arial, sans-serif",
            "fontSize": 26,
            "fontColor": { "solid": { "color": "#0B1F33" } }
          }
        ],
        "label": [
          {
            "position": "belowValue",
            "fontColor": { "solid": { "color": "#4A5568" } },
            "fontSize": 10,
            "bold": false
          }
        ],
        "outline": [
          {
            "show": true,
            "lineColor": { "solid": { "color": "#DDE3EA" } },
            "weight": 1
          }
        ],
        "shapeCustomRectangle": [
          {
            "tileShape": "rectangleRoundedByPixel",
            "rectangleRoundedCurve": 12
          }
        ],
        "accentBar": [
          {
            "show": true,
            "width": 5,
            "position": "Left",
            "color": { "solid": { "color": "#00897B" } }
          }
        ],
        "padding": [
          {
            "paddingUniform": 18
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "general": [
          {
            "responsive": true
          }
        ],
        "header": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#0B1F33" } },
            "bold": true,
            "fontSize": 10
          }
        ],
        "items": [
          {
            "fontColor": { "solid": { "color": "#0B1F33" } },
            "background": { "solid": { "color": "#FFFFFF" } },
            "padding": 10
          }
        ],
        "selection": [
          {
            "selectAllCheckboxEnabled": true,
            "singleSelect": false,
            "strictSingleSelect": false
          }
        ],
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#DDE3EA" } },
            "radius": 10
          }
        ]
      }
    },
    "clusteredBarChart": {
      "*": {
        "general": [
          {
            "responsive": true
          }
        ],
        "legend": [
          {
            "show": true,
            "position": "Top",
            "fontSize": 9
          }
        ],
        "categoryAxis": [
          {
            "show": true,
            "fontSize": 9,
            "labelColor": { "solid": { "color": "#4A5568" } },
            "gridlineShow": false,
            "concatenateLabels": false
          }
        ],
        "valueAxis": [
          {
            "show": true,
            "fontSize": 9,
            "labelColor": { "solid": { "color": "#4A5568" } },
            "gridlineShow": true,
            "gridlineColor": { "solid": { "color": "#E8EDF2" } },
            "gridlineStyle": "dotted"
          }
        ],
        "labels": [
          {
            "show": false
          }
        ]
      }
    },
    "lineChart": {
      "*": {
        "general": [
          {
            "responsive": true
          }
        ],
        "legend": [
          {
            "show": true,
            "position": "Top",
            "fontSize": 9
          }
        ],
        "categoryAxis": [
          {
            "fontSize": 9,
            "labelColor": { "solid": { "color": "#4A5568" } },
            "gridlineShow": false
          }
        ],
        "valueAxis": [
          {
            "fontSize": 9,
            "labelColor": { "solid": { "color": "#4A5568" } },
            "gridlineShow": true,
            "gridlineColor": { "solid": { "color": "#E8EDF2" } },
            "gridlineStyle": "dotted"
          }
        ],
        "lineStyles": [
          {
            "strokeWidth": 3,
            "lineStyle": "solid"
          }
        ],
        "markers": [
          {
            "show": true,
            "size": 4
          }
        ]
      }
    },
    "donutChart": {
      "*": {
        "legend": [
          {
            "show": true,
            "position": "Right",
            "fontSize": 9
          }
        ],
        "labels": [
          {
            "show": true,
            "labelStyle": "Percent of total",
            "fontSize": 9,
            "color": { "solid": { "color": "#0B1F33" } }
          }
        ]
      }
    },
    "treemap": {
      "*": {
        "legend": [
          {
            "show": false
          }
        ],
        "labels": [
          {
            "show": true,
            "fontSize": 9
          }
        ],
        "categoryLabels": [
          {
            "show": true,
            "fontSize": 10,
            "bold": true
          }
        ]
      }
    },
    "tableEx": {
      "*": {
        "grid": [
          {
            "gridVertical": true,
            "gridVerticalColor": { "solid": { "color": "#E8EDF2" } },
            "gridHorizontal": true,
            "gridHorizontalColor": { "solid": { "color": "#E8EDF2" } },
            "rowPadding": 6
          }
        ],
        "columnHeaders": [
          {
            "fontColor": { "solid": { "color": "#FFFFFF" } },
            "backColor": { "solid": { "color": "#0B3D5C" } },
            "bold": true,
            "fontSize": 10,
            "wordWrap": true
          }
        ],
        "values": [
          {
            "fontColor": { "solid": { "color": "#0B1F33" } },
            "fontSize": 9,
            "backColor": { "solid": { "color": "#FFFFFF" } },
            "alternateBackColor": { "solid": { "color": "#F8FAFC" } }
          }
        ],
        "total": [
          {
            "fontColor": { "solid": { "color": "#0B1F33" } },
            "backColor": { "solid": { "color": "#EEF2F6" } },
            "bold": true
          }
        ]
      }
    }
  }
}
